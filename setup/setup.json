{
    "setup_steps" : {
                        "CLEANUP"    : "PYTHON ./cleanup_installation.py",
                        "GENMAINDOC" : "PYTHON ./genmaindoc.py --configfile \"<json config file>\" --bundle_name \"<bundle name>\" --bundle_version \"<bundle version>\" --bundle_version_date \"<bundle version date>\"",
                        "INSTALL"    : "PYTHON -m pip install -v --proxy PROXYSETTINGS .",
                        "BUILD"      : "PYTHON -m build ."
                    },
    "setup_type" :  {
                        "install" : ["CLEANUP", "GENMAINDOC", "INSTALL"],
                        "build"   : ["GENMAINDOC", "BUILD"]
                    }
}
